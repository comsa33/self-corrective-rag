# Self-Corrective RAG — Environment Configuration
# Copy to .env and fill in your API keys.

# --- API Keys (at least one required) ---
# OPENAI_API_KEY=sk-...           # For production experiments (gpt-4o, text-embedding-3-small)
# GEMINI_API_KEY=AIza...           # For free-tier development (gemini-3.1-flash-lite-preview)

# --- LLM Model Overrides (optional) ---
# Defaults (settings.py): gpt-4o-mini (preprocess/evaluate), gpt-4o (generate/agent)
# Uncomment below for Gemini free tier:
# PREPROCESS_MODEL=gemini/gemini-3.1-flash-lite-preview
# EVALUATE_MODEL=gemini/gemini-3.1-flash-lite-preview
# GENERATE_MODEL=gemini/gemini-3.1-flash-lite-preview
# AGENT_MODEL=gemini/gemini-3.1-flash-lite-preview

# --- Embedding Model (optional) ---
# Default: text-embedding-3-small (OpenAI, requires OPENAI_API_KEY)
# For free local embeddings:
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Rate Limit (optional) ---
# Default: 3 retries. Increase for low-RPM free tier APIs.
# LLM_NUM_RETRIES=12

# --- Experiment ---
# EXPERIMENT_SEED=42
# LOG_LEVEL=INFO
